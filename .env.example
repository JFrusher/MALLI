# M.A.L.L.I. Environment Configuration Example
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file - it contains secrets!

# ============================================================================
# ML / PYTHON CONFIGURATION
# ============================================================================

# Paths
DATASET_ROOT=datasets/nih
SYNTHETIC_DATASET_ROOT=datasets/synthetic_field_ready
LOGS_DIR=experiments/logs
MODELS_DIR=experiments/logs/checkpoints

# Training
BATCH_SIZE=16
IMAGE_SIZE=224
TEST_SPLIT=0.2
SEED=42

# Model
DROPOUT_RATE=0.2
LEARNING_RATE=0.001

# Export
EXPORT_FORMATS=tflite
REPRESENTATIVE_BATCHES=100

# ============================================================================
# MOBILE / FLUTTER CONFIGURATION
# ============================================================================

# Mobile app paths
FLUTTER_APP_ROOT=../mobile
FLUTTER_ASSETS_DIR=assets/models

# Android/iOS configuration
ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-$HOME/Android/Sdk}
JAVA_HOME=${JAVA_HOME:-/usr/lib/jvm/java-11-openjdk}

# ============================================================================
# DEVELOPMENT ENVIRONMENT
# ============================================================================

# Development mode (true/false)
DEVELOPMENT_MODE=true

# Verbosity (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Use cached datasets (true/false)
USE_CACHE=true
REBUILD_CACHE=false

# ============================================================================
# CREDENTIALS (NEVER COMMIT THESE)
# ============================================================================

# API Keys (if using cloud services)
WANDB_API_KEY=
MLFLOW_TRACKING_URI=
HUGGINGFACE_TOKEN=

# Firebase (if using)
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=

# AWS (if using)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ============================================================================
# CI/CD CONFIGURATION
# ============================================================================

# GitHub Actions secrets (if using)
# Set these in GitHub repository settings, not here
# DEPLOY_KEY=
# DOCKER_USERNAME=
# DOCKER_PASSWORD=
