# =============================================================================
# M.A.L.L.I. — .gitignore
# Python ML + Flutter Android project
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# --- Virtual environments (all variants that have existed in this repo) ---
.venv/
.venv-diag/
.venv_tf/
venv/
env/

# --- ML model artifacts (large binary files) ---
*.h5
*.keras
*.weights
*.weights.h5
*.pt
*.pth
*.onnx
*.tflite
*.pb
*.pkl
*.joblib
*.npy
*.npz

# --- Dataset archives ---
*.zip
*.tar.gz
*.tar.bz2

# --- Datasets (downloaded, not committed) ---
nih_data/
datasets/nih/
datasets/blood_smear/
datasets/synthetic_field_ready/
shared/data/

# --- Training run artifacts ---
experiments/logs/checkpoints/
experiments/logs/exports/
experiments/logs/tensorboard/
experiments/logs/logs/
experiments/runs/
logs/
outputs/
*.event
events.out.tfevents.*

# --- Test / coverage ---
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/

# --- Type checking ---
.mypy_cache/
.dmypy.json
dmypy.json

# --- Jupyter ---
.ipynb_checkpoints/

# --- Flutter / Dart ---
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
mobile/build/
mobile/.dart_tool/

# --- Android build ---
mobile/android/local.properties
mobile/android/.gradle/
mobile/android/app/debug/
mobile/android/app/profile/
mobile/android/app/release/

# --- iOS build (not targeted, kept for safety) ---
mobile/ios/Pods/
mobile/ios/.symlinks/
mobile/ios/Flutter/Flutter.framework
mobile/ios/Flutter/Flutter.podspec
mobile/ios/Flutter/Generated.xcconfig
mobile/ios/Flutter/ephemeral/

# --- Environment / secrets ---
.env
.env.local
.env.*.local
*.credentials
credentials.json
service-account-key.json
google-services.json
firebase-key.json

# --- Editor / OS ---
.vscode/
.idea/
*.iml
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*~

# --- Temporary ---
*.tmp
*.temp
*.bak
*.log
.cache/

# --- TFRecord caches (regenerated on demand) ---
**/.cache/tfrecord/
**/tfrecord/

# =============================================================================
# EXCEPTIONS — files that must be committed despite matching patterns above
# =============================================================================
!mobile/assets/models/.gitkeep
!.gitignore
!.env.example
